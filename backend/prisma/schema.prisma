// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Membro {
  id                          Int                @id @default(autoincrement())
  nome                        String
  passaporte                  Int                @unique
  cargo                       String             // "Líder", "Gerente", "P1", "Elite", "Membro", "Vapor"
  discordId                   String?            // <-- NOVO: ID do Discord do membro (ex: "2839402840294820")
  criadoEm                    DateTime           @default(now())
  
  // Histórico de desempenho acumulado na semana
  acoesGanhas                 Int                @default(0)
  acoesPerdidas               Int                @default(0)
  totalDinheiroSujoArrecadado Float              @default(0)
  
  // Registro de quais itens o membro farmou na semana (salvo em formato JSON: {"Gatilho": 10, "Poliuretano": 5})
  itensFarmadosJson           Json               @default("{}")

  acoes                       ParticipanteAcao[]
}

// --- NOVA TABELA INTERMEDIÁRIA ---
model FilaDiscord {
  id          Int      @id @default(autoincrement())
  discordId   String
  novoCargo   String
  status      String   @default("PENDENTE") // "PENDENTE" ou "CONCLUIDO"
  criadoEm    DateTime @default(now())
}
model Acao {
  id                 Int                @id @default(autoincrement())
  titulo             String
  dataHora           DateTime
  tipoAcao           String             // "TIRO" ou "FUGA"
  porteAcao          String?            // "Pequena", "Média", "Grande", "Evento"
  vagasTotais        Int
  comando            String
  usaRefens          Boolean            @default(false)
  qtdRefens          Int                @default(0)
  qtdCarros          Int?
  vagasPorCarro      Int?
  criadoEm           DateTime           @default(now())
  status             String             @default("AGENDADA") 
  resultado          String?            // "GANHA", "PERDIDA", "CANCELADA"
  
  valorSujoTotal     Float?             
  pctLavagemAplicada Float?           
  valorAposLavagem   Float?             
  lucroFaccao        Float?             
  lucroMembros       Float?             
  lucroPorMembro     Float?             
  
  participantes      ParticipanteAcao[]
}

model ParticipanteAcao {
  id         Int      @id @default(autoincrement())
  acaoId     Int
  membroId   Int
  tipoVaga   String   
  inscritoEm DateTime @default(now())
  checkIn    Boolean  @default(false)    
  funcao     String   @default("Nenhuma") 

  acao       Acao     @relation(fields: [acaoId], references: [id], onDelete: Cascade)
  membro     Membro   @relation(fields: [membroId], references: [id], onDelete: Cascade)

  @@unique([acaoId, membroId])
}

model Meta {
  id               Int                @id @default(autoincrement())
  cargoAlvo        String             @unique // "LIDER", "GERENTE", "P1", "ELITE", "MEMBRO", "VAPOR"
  metaAcoes        Int                @default(0)  
  metaDinheiroSujo Float              @default(0)  
  
  // Lista de múltiplos itens exigidos para esta meta
  itensExigidos    MetaItem[]
  
  // Configurações Globais de Finanças (geralmente alteradas na meta do LIDER/GERENTE)
  pctLavagem       Float              @default(30) 
  pctFaccao        Float              @default(60) 
  pctMembros       Float              @default(40) 
  
  atualizadoEm     DateTime           @updatedAt
}

model MetaItem {
  id         Int    @id @default(autoincrement())
  metaId     Int
  nomeItem   String // Ex: "Cápsula de Munição", "Folha de Coca", "Carga de Ópio"
  quantidade Int    // Quantidade exigida na semana

  meta       Meta   @relation(fields: [metaId], references: [id], onDelete: Cascade)
}