// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Nossa primeira tabela!
model Membro {
  id         Int      @id @default(autoincrement())
  nome       String   // Nome do personagem
  passaporte Int      @unique // ID do jogo (não pode repetir)
  cargo      String   // Ex: Líder, Frente, Membro
  criadoEm   DateTime @default(now()) // Data de registro automática
  acoes ParticipanteAcao[]
}

model Acao {
  id               Int                @id @default(autoincrement())
  titulo           String
  dataHora         DateTime
  tipoAcao         String             // "TIRO" ou "FUGA"
  porteAcao        String?            // "Pequena", "Média", "Grande", "Evento"
  vagasTotais      Int
  comando          String
  usaRefens        Boolean            @default(false)
  qtdRefens        Int                @default(0)
  qtdCarros        Int?
  vagasPorCarro    Int?
  criadoEm         DateTime           @default(now())
  
  // --- NOVOS CAMPOS ---
  status           String             @default("AGENDADA") // "AGENDADA", "FORMANDO", "CONCLUIDA", "CANCELADA"
  resultado        String?            // "GANHA", "PERDIDA", "CANCELADA"
  valorSujoTotal   Float?             // Valor bruto coletado na ação
  valorAposLavagem Float?             // 70% do total (retirando os 30% da lavagem)
  lucroFaccao      Float?             // 60% do valor lavado
  lucroMembros     Float?             // 40% do valor lavado (para dividir pelo total de membros)
  lucroPorMembro   Float?             // Quanto cada um da vaga PRINCIPAL vai receber
  
  participantes    ParticipanteAcao[]
}

model ParticipanteAcao {
  id         Int      @id @default(autoincrement())
  acaoId     Int
  membroId   Int
  tipoVaga   String   // "PRINCIPAL" ou "RESERVA"
  inscritoEm DateTime @default(now())
  
  // --- NOVOS CAMPOS ---
  checkIn    Boolean  @default(false)    // Se o membro marcou que "tá na HQ"
  funcao     String   @default("Nenhuma") // Ex: "Piloto", "Atirador", "Negociador"

  acao       Acao     @relation(fields: [acaoId], references: [id], onDelete: Cascade)
  membro     Membro   @relation(fields: [membroId], references: [id], onDelete: Cascade)

  @@unique([acaoId, membroId])
}